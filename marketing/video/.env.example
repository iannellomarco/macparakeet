# ElevenLabs API key for voiceover generation.
# Get one at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Voice ID. Defaults to a calm, professional voice if unset.
# Browse voices at https://elevenlabs.io/app/voice-library
# Brand voice direction: calm, confident, minimal. Slight warmth. Not robotic.
ELEVENLABS_VOICE_ID=

# Model. eleven_turbo_v2_5 is the current high-quality/low-latency default.
# Use eleven_multilingual_v2 for non-English VO.
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
